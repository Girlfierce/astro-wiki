---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
---

<BaseLayout title="Blog - Astro Wiki">
  <div class="min-h-screen py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-5xl font-bold mb-4 text-white">Blog</h1>
      <p class="text-xl text-gray-400 mb-16">Exploring knowledge architecture, creative systems, and semantic understanding</p>
      
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <article class="bg-gray-900 rounded-lg overflow-hidden hover:scale-105 transition-transform duration-300">
            <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="block">
              <div class="p-6">
                <div class="flex items-center gap-2 mb-4">
                  <span class="px-3 py-1 bg-purple-900 text-purple-300 text-xs rounded-full uppercase">
                    {post.data.muse}
                  </span>
                  <span class="px-3 py-1 bg-blue-900 text-blue-300 text-xs rounded-full uppercase">
                    {post.data.paraType}
                  </span>
                </div>
                <h2 class="text-2xl font-bold text-white mb-2">{post.data.title}</h2>
                <p class="text-gray-400 mb-4">{post.data.description}</p>
                <div class="flex items-center justify-between text-sm text-gray-500">
                  <span>{post.data.pubDate.toLocaleDateString()}</span>
                  <span>{post.data.readingTime} min read</span>
                </div>
                <div class="mt-4 flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="px-2 py-1 bg-gray-800 text-gray-400 text-xs rounded">
                      #{tag}
                    </span>
                  ))}
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
