---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props as Props;

function getMuseIcon(muse?: string): string {
  const icons: Record<string, string> = {
    euterpe: '🎵',
    thalia: '✨',
    erato: '💜',
    polymnia: '🌙',
    melpomene: '⚡',
    urania: '🔭',
    clio: '📜',
    calliope: '📝',
    terpsichore: '💃',
    void: '⚫',
  };
  return muse ? icons[muse] || '📖' : '📖';
}
---

<div id="gallery-container" class="relative min-h-screen overflow-hidden">
  <canvas id="webgl-canvas" class="absolute inset-0 w-full h-full"></canvas>
  
  <div id="gallery-content" class="relative z-10">
    <header class="text-center py-20 px-6">
      <h1 class="text-6xl md:text-8xl font-bold text-white mb-4 tracking-tight">
        Astro Wiki
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto">
        A semantic knowledge architecture exploring the intersection of creativity, systems thinking, and digital organization
      </p>
    </header>

    <div id="gallery-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 px-6 pb-20 max-w-7xl mx-auto">
      {posts.map((post, index) => (
        <a
          href={`/blog/${post.id.replace(/\.md$/, '')}`}
          class="gallery-item group relative bg-gray-900/80 backdrop-blur-sm rounded-xl overflow-hidden border border-gray-800 hover:border-purple-500 transition-all duration-500"
          data-index={index}
        >
          <div class="aspect-video bg-gradient-to-br from-purple-900 to-blue-900 relative overflow-hidden">
            <div class="absolute inset-0 flex items-center justify-center text-6xl opacity-20">
              {getMuseIcon(post.data.muse)}
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-transparent to-transparent"></div>
          </div>
          
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="px-3 py-1 bg-purple-900/50 text-purple-300 text-xs rounded-full uppercase tracking-wide">
                {post.data.muse}
              </span>
              <span class="px-3 py-1 bg-blue-900/50 text-blue-300 text-xs rounded-full uppercase tracking-wide">
                {post.data.paraType}
              </span>
            </div>
            
            <h2 class="text-xl font-bold text-white mb-2 group-hover:text-purple-400 transition-colors">
              {post.data.title}
            </h2>
            
            <p class="text-gray-400 text-sm line-clamp-2">
              {post.data.description}
            </p>
            
            <div class="mt-4 flex items-center justify-between text-xs text-gray-500">
              <span>{post.data.readingTime} min read</span>
              <span class="group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Simple WebGL background effect
  const canvas = document.getElementById('webgl-canvas') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d');
    if (ctx) {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;

      const particles: Array<{ x: number; y: number; vx: number; vy: number; size: number }> = [];
      const particleCount = 100;

      for (let i = 0; i < particleCount; i++) {
        particles.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          vx: (Math.random() - 0.5) * 0.5,
          vy: (Math.random() - 0.5) * 0.5,
          size: Math.random() * 2 + 1,
        });
      }

      function animate() {
        ctx.fillStyle = 'rgba(3, 7, 18, 0.1)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        particles.forEach((p) => {
          p.x += p.vx;
          p.y += p.vy;

          if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
          if (p.y < 0 || p.y > canvas.height) p.vy *= -1;

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(139, 92, 246, 0.5)';
          ctx.fill();
        });

        requestAnimationFrame(animate);
      }

      animate();

      window.addEventListener('resize', () => {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      });
    }
  }

  // GSAP animations for gallery items
  const items = document.querySelectorAll('.gallery-item');
  
  gsap.from(items, {
    scrollTrigger: {
      trigger: '#gallery-grid',
      start: 'top 80%',
    },
    y: 100,
    opacity: 0,
    duration: 0.8,
    stagger: 0.1,
    ease: 'power3.out',
  });

  // Header animation
  gsap.from('header h1', {
    y: 50,
    opacity: 0,
    duration: 1,
    ease: 'power3.out',
    delay: 0.2,
  });

  gsap.from('header p', {
    y: 30,
    opacity: 0,
    duration: 1,
    ease: 'power3.out',
    delay: 0.4,
  });
</script>

<style>
  #webgl-canvas {
    pointer-events: none;
  }
  
  .gallery-item:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(139, 92, 246, 0.2);
  }
  
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
